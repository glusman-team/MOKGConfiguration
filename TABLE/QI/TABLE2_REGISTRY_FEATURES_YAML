name: "Table2_Registry_Features_YAML"
version: "1.0"
description: "Comparison of Rheumatry with Major International Rheumatology Registries"

sections:
  - name: "feature"
    type: "text"
    constraints:
      - pattern: ".+"
      - not_empty: true
    description: "Registry feature being compared"
    
  - name: "registry"
    type: "text"
    constraints:
      - one_of: ["Rheumatry (Iran)", "CorEvitas / CORRONA [1] (USA)", "Reuma.pt [10] (Portugal)", "BSRBR-RA [2] (UK)", "EUSTAR [3] (Europe)"]
    description: "Registry name"
    
  - name: "feature_value"
    type: "text"
    description: "Value/implementation of the feature in the registry"

entities:
  - name: "registry_entity"
    source: "registry"
    constraints:
      - unique: true
    description: "Represents rheumatology registries"

predicates:
  - name: "has_feature"
    subject: "registry_entity"
    object: "feature_value"
    description: "Indicates that a registry has a specific feature with its value"

relationships:
  - subject: "registry_entity"
    predicate: "has_feature"
    object: "feature_value"
    extraction:
      strategy: "row_to_triples"
      pattern: ".*"
      delimiter: ","
      fields:
        - "registry"
        - "feature"
        - "feature_value"

transformations:
  - field: "registry"
    operations:
      - trim: true
      - remove: "^\\s*\\d+[\\.\\s]*"
      - replace: ["\\s+", "_"]
      - prefix: "registry:"
      
  - field: "feature"
    operations:
      - trim: true
      - remove: "^\\s*\\d+[\\.\\s]*"
      - replace: ["\\s+", "_"]
      - prefix: "feature:"
      
  - field: "feature_value"
    operations:
      - trim: true

validation:
  - check: "all_required_fields_present"
    fields: ["registry", "feature", "feature_value"]
    
  - check: "no_duplicate_registries"
    field: "registry"

output_format: "triples"
