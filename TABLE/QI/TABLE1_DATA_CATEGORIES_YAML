name: "Table1_Data_Categories_YAML"
version: "1.0"
description: "Key data elements in Rheumatry intake (baseline) forms, by disease"

sections:
  - name: "data_category"
    type: "text"
    constraints:
      - pattern: ".+"
      - not_empty: true
    description: "Data category collected in rheumatry intake forms"
    
  - name: "diseases"
    type: "array"
    item_type: "text"
    constraints:
      - one_of: ["RA", "SLE", "SSc", "AS", "TAK"]
    description: "Diseases for which data is collected"

entities:
  - name: "data_category_entity"
    source: "data_category"
    constraints:
      - unique: true
    description: "Represents data categories collected in rheumatry forms"

predicates:
  - name: "collected_for"
    subject: "data_category_entity"
    object: "disease"
    description: "Indicates that a data category is collected for a specific disease"

relationships:
  - subject: "data_category_entity"
    predicate: "collected_for"
    object: "disease"
    extraction:
      strategy: "row_to_triples"
      pattern: ".*"
      delimiter: ","
      fields:
        - "data_category"
        - "diseases"

transformations:
  - field: "data_category"
    operations:
      - trim: true
      - remove: "^[\\s\\d\\.\\-]+"
      - replace: ["\\s+", "_"]
      
  - field: "diseases"
    operations:
      - explode_by: ","
      - trim: true
      - prefix: "disease:"

validation:
  - check: "all_required_fields_present"
    fields: ["data_category", "diseases"]
    
  - check: "no_duplicate_data_categories"
    field: "data_category"

output_format: "triples"
