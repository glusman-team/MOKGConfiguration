d><td align="left" valign="top" colspan="1" rowspan="1">&#x02003;</td></tr><tr><td align="left" valign="top" colspan="1" rowspan="1">Any comorbidity (<italic toggle="yes">n</italic>, %)</td><td align="left" valign="top" colspan="1" rowspan="1">280 (75.7)</td><td align="left" valign="top" colspan="1" rowspan="1">126 (94.7)</td><td align="left" valign="top" colspan="1" rowspan="1">30 (49.2)</td><td align="left" valign="top" colspan="1" rowspan="1">57 (80.3)</td><td align="left" valign="top" colspan="1" rowspan="1">16 (72.7)</td><td align="left" valign="top" colspan="1" rowspan="1">23 (85.2)</td><td align="left" valign="top" colspan="1" rowspan="1">39 (69.6)</td><td align="left" valign="top" colspan="1" rowspan="1">16 (31.4) <xref rid="T1_FN1" ref-type="table-fn"><sup><italic toggle="yes">a</italic></sup></xref></td></tr><tr><td align="left" valign="top" colspan="1" rowspan="1">Diabetes mellitus (<italic toggle="yes">n</italic>, %)</td><td align="left" valign="top" colspan="1" rowspan="1">29 (7.8)</td><td align="left" valign="top" colspan="1" rowspan="1">19 (14.3)</td><td align="left" valign="top" colspan="1" rowspan="1">2 (3.3)</td><td align="left" valign="top" colspan="1" rowspan="1">6 (8.5)</td><td align="left" valign="top" colspan="1" rowspan="1">1 (4.5)</td><td align="left" valign="top" colspan="1" rowspan="1">3 (11.1)</td><td align="left" valign="top" colspan="1" rowspan="1">3 (5.4)</td><td align="left" valign="top" colspan="1" rowspan="1">1 (2.0)</td></tr><tr><td align="left" valign="top" colspan="1" rowspan="1">Hypertension (<italic toggle="yes">n</italic>, %)</td><td align="left" valign="top" colspan="1" rowspan="1">85 (23.0)</td><td align="left" valign="top" colspan="1" rowspan="1">31 (23.3)</td><td align="left" valign="top" colspan="1" rowspan="1">6 (9.8)</td><td align="left" valign="top" colspan="1" rowspan="1">21 (29.6)</td><td align="left" valign="top" colspan="1" rowspan="1">6 (27.3)</td><td align="left" valign="top" colspan="1" rowspan="1">8 (29.6)</td>